import javafx.application.Application;
import javafx.scene.Scene;
import javafx.scene.layout.VBox;
import javafx.scene.layout.HBox;
import javafx.scene.paint.Color;
import javafx.scene.shape.Rectangle;
import javafx.scene.control.Label;
import javafx.stage.Stage;
import javafx.geometry.Pos;

public class Q35BarChart extends Application {

    public void start(Stage stage) {

        // Scale factor for height
        int scale = 5;

        // Create bars
        Rectangle r1 = new Rectangle(50, 20 * scale, Color.RED);
        Rectangle r2 = new Rectangle(50, 10 * scale, Color.BLUE);
        Rectangle r3 = new Rectangle(50, 30 * scale, Color.GREEN);
        Rectangle r4 = new Rectangle(50, 40 * scale, Color.ORANGE);

        // Labels
        Label l1 = new Label("Projects - 20%");
        Label l2 = new Label("Quizzes - 10%");
        Label l3 = new Label("Midterm - 30%");
        Label l4 = new Label("Final - 40%");

        // VBox for each bar + label
        VBox box1 = new VBox(5, r1, l1);
        VBox box2 = new VBox(5, r2, l2);
        VBox box3 = new VBox(5, r3, l3);
        VBox box4 = new VBox(5, r4, l4);

        box1.setAlignment(Pos.BOTTOM_CENTER);
        box2.setAlignment(Pos.BOTTOM_CENTER);
        box3.setAlignment(Pos.BOTTOM_CENTER);
        box4.setAlignment(Pos.BOTTOM_CENTER);

        // HBox to arrange bars horizontally
        HBox root = new HBox(20, box1, box2, box3, box4);
        root.setAlignment(Pos.CENTER);

        Scene scene = new Scene(root, 500, 300);

        stage.setTitle("Grade Distribution Bar Chart");
        stage.setScene(scene);
        stage.show();
    }

    public static void main(String[] args) {
        launch(args);
    }
}
