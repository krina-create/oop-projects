class Volume {

    // Volume of cube
    double volume(double side) {
        return side * side * side;
    }

    // Volume of cuboid
    double volume(double length, double width, double height) {
        return length * width * height;
    }

    // Volume of cylinder
    double volume(double radius, double height, boolean isCylinder) {
        return Math.PI * radius * radius * height;
    }
}

public class VolumeTest {
    public static void main(String[] args) {

        Volume v = new Volume();

        // Cube
        double cubeVolume = v.volume(3);

        // Cuboid
        double cuboidVolume = v.volume(4, 5, 6);

        // Cylinder (boolean used only to differentiate method)
        double cylinderVolume = v.volume(3, 7, true);

        System.out.println("Volume of Cube: " + cubeVolume);
        System.out.println("Volume of Cuboid: " + cuboidVolume);
        System.out.println("Volume of Cylinder: " + cylinderVolume);
    }
}
